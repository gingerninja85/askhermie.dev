---
import '../styles/site.css';
import SeoHead from '../components/SeoHead.astro';

const nav = [
  ['Resources', '/resources'],
  ['About', '/about'],
  ['Hermes Docs', 'https://hermes-agent.nousresearch.com/docs/'],
  ['GitHub Repo', 'https://github.com/gingerninja85/askhermie.dev'],
];

const method = [
  {
    title: 'Find useful tools',
    desc: 'Search the internet and GitHub for tools that actually work with Hermes, systems engineering, AI, cyber, IoT, and hardware labs.',
    tag: 'discover',
  },
  {
    title: 'Make them usable',
    desc: 'No vague “check this out” summaries. Each resource gets a plain-English purpose and a copy/paste first command when possible.',
    tag: 'simplify',
  },
  {
    title: 'Turn use into skill',
    desc: 'When a workflow proves useful, Hermie can turn it into a reusable skill so the next run starts smarter.',
    tag: 'learn',
  },
];


const seoKeywords = [
  'Hermes Agent',
  'AI agent tools',
  'AI automation tools',
  'MCP tools',
  'local AI tools',
  'cybersecurity lab tools',
  'IoT lab tools',
  'firmware analysis tools',
  'systems engineering tools',
  'copy paste install commands',
];

const homeStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'askhermie.dev',
    url: 'https://askhermie.dev/',
    description: 'A practical resource map for useful AI-agent tools, automation, cybersecurity learning, IoT, firmware, and systems engineering, with plain-English notes and first commands.',
    inLanguage: 'en-NZ',
    publisher: {
      '@type': 'Organization',
      name: 'Hermie',
      url: 'https://askhermie.dev/',
      logo: 'https://askhermie.dev/assets/hermie-avatar.png',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Core askhermie.dev pages',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Resource Map', url: 'https://askhermie.dev/resources/' },
      { '@type': 'ListItem', position: 2, name: 'About Hermie', url: 'https://askhermie.dev/about/' },
      { '@type': 'ListItem', position: 3, name: 'Hermes Agent Docs', url: 'https://hermes-agent.nousresearch.com/docs/' },
    ],
  },
];

const tools = [
  {
    name: 'Hermes Agent',
    desc: 'The AI agent system behind Hermie: tools, skills, memory, gateway, cron, desktop, and CLI.',
    href: 'https://hermes-agent.nousresearch.com/docs/',
    cta: 'Read Hermes docs',
  },
  {
    name: 'Cloudflare Pages + Astro',
    desc: 'The deployment stack for this site: GitHub push in, global static site out.',
    href: 'https://github.com/gingerninja85/askhermie.dev',
    cta: 'View site source',
  },
  {
    name: 'Resource Map',
    desc: 'Curated tools and learning resources with simple first steps and install commands.',
    href: '/resources',
    cta: 'Browse resources',
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title="askhermie.dev — useful AI and tech tools in plain English"
      description="Find practical AI-agent, automation, cybersecurity, IoT, firmware, and systems tools with plain-English notes and copy/paste first commands."
      path="/"
      keywords={seoKeywords}
      image="/assets/askhermie-og.png"
      structuredData={homeStructuredData}
    />
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Hermie home">
        <img src="/assets/hermie-avatar.png" alt="Byte Badger mascot avatar for Hermie" />
        <span>Hermie</span>
      </a>
      <nav aria-label="Primary navigation">
        {nav.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
    </header>

    <main>
      <section class="hero hermes-explainer-hero">
        <div class="hero-copy">
          <p class="eyebrow">Useful tech // plain English</p>
          <h1>Useful AI and tech tools, explained.</h1>
          <p class="lede"><strong>askhermie.dev is a practical resource map.</strong> It points you at tools for AI agents, automation, cybersecurity labs, IoT, firmware, hardware hacking, and systems engineering — then explains what each tool is for and how to start.</p>
          <p class="simple-line">Hermie is the Hermes Agent assistant behind the site: AI that can use approved tools, run commands, browse, remember workflows, and help turn confusing technical work into repeatable steps.</p>
          <div class="actions">
            <a class="button primary" href="/resources">Browse useful tools</a>
            <a class="button secondary" href="https://hermes-agent.nousresearch.com/docs/">What is Hermes?</a>
          </div>
        </div>
        <aside class="identity-card comparison-card" aria-label="What askhermie.dev gives you">
          <p class="card-label">What you get here</p>
          <div class="compare-row active-row">
            <span>Resource map</span>
            <strong>Tools worth trying</strong>
            <p>Short notes, source links, example uses, and copy/paste first commands when installation makes sense.</p>
          </div>
          <div class="compare-row muted-row">
            <span>Hermes explainer</span>
            <strong>Why AI agents matter</strong>
            <p>Plain-English guides to how Hermes differs from normal chatbots like ChatGPT, Claude, or Gemini.</p>
          </div>
          <p class="tiny-note">Best for beginners, curious builders, and systems/cyber/IoT learners who want practical starting points instead of random link dumps.</p>
        </aside>
      </section>

      <section class="section about-preview hermes-basics" aria-labelledby="about-preview-heading">
        <div>
          <p class="eyebrow">How to use it</p>
          <h2 id="about-preview-heading">Pick a topic, copy the first step, build confidence.</h2>
        </div>
        <div class="basics-grid">
          <article>
            <strong>Find the right tool.</strong>
            <p>Browse practical resources for AI agents, automation, systems work, cybersecurity labs, IoT projects, firmware, and hardware learning.</p>
          </article>
          <article>
            <strong>Understand why it matters.</strong>
            <p>Each entry uses plain English: what the tool does, what you would actually use it for, and what to watch out for.</p>
          </article>
          <article>
            <strong>Start with one command.</strong>
            <p>Where possible, resources include a copy/paste first command or a safe starting link so you can try the tool instead of just reading about it.</p>
          </article>
          <a class="button secondary" href="/resources">Open the resource map</a>
        </div>
      </section>


      <section id="method" class="section">
        <div class="section-head">
          <p class="eyebrow">Method</p>
          <h2>Find useful tech, then make it less annoying.</h2>
          <p>The job is not to collect links. The job is to turn useful tools into simple first steps that a normal technical human can actually follow.</p>
        </div>
        <div class="grid cards">
          {method.map((item) => (
            <article class="card">
              <span>{item.tag}</span>
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="tools" class="section two-col">
        <div>
          <p class="eyebrow">Tools</p>
          <h2>Built around practical use, not hype.</h2>
          <p>The resource map focuses on tools that either integrate with Hermes directly or help with real technical work: deployment, automation, AI, systems, cyber, IoT, firmware, and lab learning.</p>
          <div class="actions small-actions">
            <a class="button primary" href="/resources">Browse resources</a>
          </div>
        </div>
        <div class="tool-list">
          {tools.map((tool) => (
            <a class="tool-card-link" href={tool.href}>
              <article>
                <h3>{tool.name}</h3>
                <p>{tool.desc}</p>
                <span>{tool.cta} →</span>
              </article>
            </a>
          ))}
        </div>
      </section>

      <section id="lab" class="section lab-panel">
        <p class="eyebrow">Lab direction</p>
        <h2>AI, automation, cybersecurity, IoT, firmware, and systems engineering.</h2>
        <p>This site is becoming a practical map for what Hermie can use, what is worth learning, and how to start without drowning in setup complexity. The first resource page is live-ready: tools, install commands, and simple first moves.</p>
      </section>

      <section id="build-log" class="section timeline">
        <div>
          <p class="eyebrow">Build log</p>
          <h2>What Hermie learned or shipped.</h2>
        </div>
        <div class="timeline-items">
          <article>
            <time>Now</time>
            <h3>Resource map added</h3>
            <p>Curated tools and learning resources with copy/paste install commands and plain-English first steps.</p>
          </article>
          <article>
            <time>Next</time>
            <h3>Search and filters</h3>
            <p>Add Pagefind search plus category filters so the catalog is useful once it grows.</p>
          </article>
        </div>
      </section>
    </main>

    <footer>
      <p>Built with Hermie ⚙️</p>
      <p>askhermie.dev</p>
    </footer>
  </body>
</html>
