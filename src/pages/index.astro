---
import '../styles/site.css';
import SeoHead from '../components/SeoHead.astro';

const nav = [
  ['Resources', '/resources'],
  ['About', '/about'],
  ['Hermes Docs', 'https://hermes-agent.nousresearch.com/docs/'],
  ['GitHub Repo', 'https://github.com/gingerninja85/askhermie.dev'],
];

const method = [
  {
    title: 'Find useful tools',
    desc: 'Search the internet and GitHub for tools that actually work with Hermes, systems engineering, AI, cyber, IoT, and hardware labs.',
    tag: 'discover',
  },
  {
    title: 'Make them usable',
    desc: 'No vague “check this out” summaries. Each resource gets a plain-English purpose and a copy/paste first command when possible.',
    tag: 'simplify',
  },
  {
    title: 'Turn use into skill',
    desc: 'When a workflow proves useful, Hermie can turn it into a reusable skill so the next run starts smarter.',
    tag: 'learn',
  },
];


const seoKeywords = [
  'Hermes Agent',
  'AI agent tools',
  'AI automation tools',
  'MCP tools',
  'local AI tools',
  'cybersecurity lab tools',
  'IoT lab tools',
  'firmware analysis tools',
  'systems engineering tools',
  'copy paste install commands',
];

const homeStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'askhermie.dev',
    url: 'https://askhermie.dev/',
    description: 'A practical resource map for Hermes Agent, AI-agent tooling, automation, cybersecurity learning, IoT, firmware, and systems engineering tools.',
    inLanguage: 'en-NZ',
    publisher: {
      '@type': 'Organization',
      name: 'Hermie',
      url: 'https://askhermie.dev/',
      logo: 'https://askhermie.dev/assets/hermie-avatar.png',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Core askhermie.dev pages',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Resource Map', url: 'https://askhermie.dev/resources/' },
      { '@type': 'ListItem', position: 2, name: 'About Hermie', url: 'https://askhermie.dev/about/' },
      { '@type': 'ListItem', position: 3, name: 'Hermes Agent Docs', url: 'https://hermes-agent.nousresearch.com/docs/' },
    ],
  },
];

const tools = [
  {
    name: 'Hermes Agent',
    desc: 'The AI agent system behind Hermie: tools, skills, memory, gateway, cron, desktop, and CLI.',
    href: 'https://hermes-agent.nousresearch.com/docs/',
    cta: 'Read Hermes docs',
  },
  {
    name: 'Cloudflare Pages + Astro',
    desc: 'The deployment stack for this site: GitHub push in, global static site out.',
    href: 'https://github.com/gingerninja85/askhermie.dev',
    cta: 'View site source',
  },
  {
    name: 'Resource Map',
    desc: 'Curated tools and learning resources with simple first steps and install commands.',
    href: '/resources',
    cta: 'Browse resources',
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title="What is Hermes? AI that can use tools and do tasks"
      description="Plain-English guide to Hermes Agent: what it is, what it can do, and why it is different from just chatting with ChatGPT, Claude, or Gemini."
      path="/"
      keywords={seoKeywords}
      structuredData={homeStructuredData}
    />
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Hermie home">
        <img src="/assets/hermie-avatar.png" alt="Hermie avatar" />
        <span>Hermie</span>
      </a>
      <nav aria-label="Primary navigation">
        {nav.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
    </header>

    <main>
      <section class="hero hermes-explainer-hero">
        <div class="hero-copy">
          <p class="eyebrow">Hermes Agent // plain English</p>
          <h1>Hermes is AI that can do the job.</h1>
          <p class="lede"><strong>ChatGPT, Claude, and Gemini mostly answer questions.</strong> Hermes can use tools: read files, run commands, open browsers, remember useful context, follow workflows, schedule jobs, and help control real apps or systems when you allow it.</p>
          <p class="simple-line">Think of it like this: normal chatbots are clever advisers. Hermes is a workbench assistant that can help carry out the job.</p>
          <div class="actions">
            <a class="button primary" href="https://hermes-agent.nousresearch.com/docs/">Read Hermes docs</a>
            <a class="button secondary" href="/resources">Browse useful tools</a>
          </div>
        </div>
        <aside class="identity-card comparison-card" aria-label="Why Hermes is different from normal chatbots">
          <p class="card-label">The simple difference</p>
          <div class="compare-row muted-row">
            <span>Normal chatbot</span>
            <strong>Talks about the task</strong>
            <p>Good for explanations, drafts, and advice.</p>
          </div>
          <div class="compare-row active-row">
            <span>Hermes Agent</span>
            <strong>Can help do the task</strong>
            <p>Uses approved tools, files, browser, terminal, memory, skills, messaging, and scheduled automation.</p>
          </div>
          <p class="tiny-note">You stay in control: Hermes asks before risky actions and works best when pointed at your own files, accounts, labs, or systems.</p>
        </aside>
      </section>

      <section class="section about-preview hermes-basics" aria-labelledby="about-preview-heading">
        <div>
          <p class="eyebrow">What can it do?</p>
          <h2 id="about-preview-heading">A simple map of Hermes.</h2>
        </div>
        <div class="basics-grid">
          <article>
            <strong>It can work with your computer.</strong>
            <p>Read project files, run tests, inspect logs, use a browser, edit code, and verify the result instead of only giving instructions.</p>
          </article>
          <article>
            <strong>It can remember useful context.</strong>
            <p>Hermes can keep preferences, environment notes, and reusable skills so you do not have to explain the same workflow every time.</p>
          </article>
          <article>
            <strong>It can run outside one chat tab.</strong>
            <p>Use Hermes from a terminal, desktop app, Telegram, Discord, email, cron jobs, webhooks, and other connected surfaces.</p>
          </article>
          <a class="button secondary" href="/about">Read the full about page</a>
        </div>
      </section>

      <section class="section seo-focus" aria-labelledby="seo-focus-heading">
        <div class="section-head">
          <p class="eyebrow">What people come here for</p>
          <h2 id="seo-focus-heading">AI-agent tools, lab utilities, and practical install notes.</h2>
          <p>askhermie.dev is built for people searching for a sane starting point: Hermes Agent resources, AI automation tools, MCP servers, local AI setups, cybersecurity practice labs, IoT projects, firmware analysis utilities, homelab monitoring, and Windows/WSL-friendly setup notes.</p>
        </div>
      </section>

      <section id="method" class="section">
        <div class="section-head">
          <p class="eyebrow">Method</p>
          <h2>Find useful tech, then make it less annoying.</h2>
          <p>The job is not to collect links. The job is to turn useful tools into simple first steps that a normal technical human can actually follow.</p>
        </div>
        <div class="grid cards">
          {method.map((item) => (
            <article class="card">
              <span>{item.tag}</span>
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="tools" class="section two-col">
        <div>
          <p class="eyebrow">Tools</p>
          <h2>Built around practical use, not hype.</h2>
          <p>The resource map focuses on tools that either integrate with Hermes directly or help with real technical work: deployment, automation, AI, systems, cyber, IoT, firmware, and lab learning.</p>
          <div class="actions small-actions">
            <a class="button primary" href="/resources">Browse resources</a>
          </div>
        </div>
        <div class="tool-list">
          {tools.map((tool) => (
            <a class="tool-card-link" href={tool.href}>
              <article>
                <h3>{tool.name}</h3>
                <p>{tool.desc}</p>
                <span>{tool.cta} →</span>
              </article>
            </a>
          ))}
        </div>
      </section>

      <section id="lab" class="section lab-panel">
        <p class="eyebrow">Lab direction</p>
        <h2>AI, automation, cybersecurity, IoT, firmware, and systems engineering.</h2>
        <p>This site is becoming a practical map for what Hermie can use, what is worth learning, and how to start without drowning in setup complexity. The first resource page is live-ready: tools, install commands, and simple first moves.</p>
      </section>

      <section id="build-log" class="section timeline">
        <div>
          <p class="eyebrow">Build log</p>
          <h2>What Hermie learned or shipped.</h2>
        </div>
        <div class="timeline-items">
          <article>
            <time>Now</time>
            <h3>Resource map added</h3>
            <p>Curated tools and learning resources with copy/paste install commands and plain-English first steps.</p>
          </article>
          <article>
            <time>Next</time>
            <h3>Search and filters</h3>
            <p>Add Pagefind search plus category filters so the catalog is useful once it grows.</p>
          </article>
        </div>
      </section>
    </main>

    <footer>
      <p>Built with Hermie ⚙️</p>
      <p>askhermie.dev</p>
    </footer>
  </body>
</html>
