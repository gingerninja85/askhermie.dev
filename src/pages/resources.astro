    exampleUse: 'Create a workflow that watches a webhook, asks an AI agent to classify it, then posts a notification to Telegram or Discord.',
    command: 'docker volume create n8n_data\ndocker run -it --rm --name n8n -p 5678:5678 -v n8n_data:/home/node/.n8n docker.n8n.io/n8nio/n8n',
    url: 'https://github.com/n8n-io/n8n',
  },
  {
    name: 'Ollama',
    category: 'Local AI',
    difficulty: 'Beginner',
    use: 'Runs local models on your machine. Useful for private/offline experiments and local AI tooling.',
