  {
    name: 'esptool-js',
    category: 'ESP browser flashing',
    difficulty: 'Intermediate',
    use: 'Espressif’s JavaScript/WebSerial implementation of esptool for browser-based ESP32 and ESP8266 flashing workflows.',
    firstStep: 'Use the official demo or a local test page with a spare dev board before embedding flashing into your own project docs.',
    exampleUse: 'Add a browser flasher to an ESP32 workshop page so learners can install known firmware without a Python toolchain first.',
    command: 'npm install --save esptool-js',
    safetyNote: 'Flashing firmware can erase devices or install the wrong image. Use known firmware, check board targets, and avoid customer or safety-critical devices.',
    url: 'https://github.com/espressif/esptool-js',
  },
  {
    name: 'FACT',
    category: 'Firmware analysis platform',
    difficulty: 'Advanced',
    use: 'Firmware Analysis and Comparison Tool for unpacking firmware, identifying components, and summarizing security-relevant findings.',
    firstStep: 'Use the documented Vagrant path on a lab VM before attempting a local install on your main workstation.',
    exampleUse: 'Compare two router firmware images to see changed components, embedded files, and likely security-relevant differences.',
    command: '# Start with the maintained install docs:\n# https://github.com/fkie-cad/FACT_core/blob/master/INSTALL.md',
    safetyNote: 'Firmware images can contain proprietary code, secrets, keys, or personal data. Analyze only firmware you are allowed to inspect and do not publish extracted secrets.',
    url: 'https://github.com/fkie-cad/FACT_core',
  },
  {
    name: 'FastAPI Observability',
    category: 'Observability tutorial',
    difficulty: 'Intermediate',
    use: 'Working FastAPI example wired to OpenTelemetry, Prometheus, Tempo, Loki, and Grafana so logs, metrics, and traces line up.',
    firstStep: 'Run the compose stack locally, generate traffic, and trace one request across Grafana before copying patterns into your own app.',
    exampleUse: 'Learn what OpenTelemetry spans, Prometheus metrics, Loki logs, and Grafana dashboards look like in a real Python web app.',
    command: 'git clone --depth 1 https://github.com/blueswen/fastapi-observability.git ~/labs/fastapi-observability\ncd ~/labs/fastapi-observability\ndocker compose up -d',
    safetyNote: 'Demo observability stacks open local ports and collect request/log data. Keep it local and avoid sending real user data into a lab stack.',
    url: 'https://github.com/blueswen/fastapi-observability',
  },
  {
    name: 'OpenTelemetry Collector',
    category: 'Observability collector',
    difficulty: 'Intermediate',
    use: 'Vendor-neutral service for receiving, processing, and exporting telemetry data across traces, metrics, and logs.',
    firstStep: 'Run the contrib container with a tiny local config and send sample telemetry before touching production pipelines.',
    exampleUse: 'Receive app traces locally, scrub or transform attributes, then export them to a chosen backend without changing every app.',
    command: 'docker run --rm otel/opentelemetry-collector-contrib:latest --version',
    safetyNote: 'Collectors can forward sensitive headers, labels, logs, traces, and host metadata. Redact secrets and test routing locally before exporting anywhere.',
    url: 'https://github.com/open-telemetry/opentelemetry-collector',
  },
  {
    name: 'agent-inspect',
    category: 'AI agent run inspection',
    difficulty: 'Intermediate',
    use: 'Local execution-tree recorder for TypeScript AI agents, covering tool calls, LLM steps, retries, failures, timings, and share-safe reports.',
    firstStep: 'Initialize it in a throwaway TypeScript agent project and inspect one demo trace before instrumenting real workflows.',
    exampleUse: 'Debug why a Node-based agent repeated a tool call or failed halfway through a task without uploading traces to a hosted dashboard.',
    command: 'npm install agent-inspect\nnpx agent-inspect init --yes\nnpx agent-inspect verify-safe --dir .agent-inspect',
    safetyNote: 'Agent traces can include prompts, tool outputs, filenames, logs, and user data. Keep traces local and run redaction/verify-safe before sharing artifacts.',
    url: 'https://github.com/rajudandigam/agent-inspect',
  },
  {
    name: 'DashClaw',
    category: 'AI agent governance',
    difficulty: 'Advanced',
    use: 'Governance layer for AI agents that evaluates risky actions, routes human approvals, and records audit trails before agents touch real systems.',
    firstStep: 'Read the local/hosted quickstart and test one toy governed action before connecting shell, browser, cloud, or production tools.',
    exampleUse: 'Put an approval gate in front of an experimental agent so deploys, file writes, or external actions require policy checks instead of blind execution.',
    command: 'npm install -g @dashclaw/cli\ndashclaw --help',
    safetyNote: 'Governance tools sit in the path of prompts, actions, approvals, and logs. Test with fake data first and treat audit logs as sensitive.',
    url: 'https://github.com/ucsandman/DashClaw',
  },
  {
    name: 'goose',
    category: 'AI coding agent',
    difficulty: 'Intermediate',
    use: 'Open-source desktop and CLI agent for coding and workflow automation, now under the Linux Foundation Agentic AI Foundation.',
    firstStep: 'Install the CLI or desktop app, configure a throwaway provider key, and run it in a disposable repo before granting access to important projects.',
    exampleUse: 'Compare how another local coding agent plans, edits, and tests a small bugfix next to Hermes, Claude Code, or Codex workflows.',
    command: '# Official CLI installer from the project release docs:\n# curl -fsSL https://github.com/aaif-goose/goose/releases/download/stable/download_cli.sh | bash\n# Then check:\ngoose --help',
    safetyNote: 'Coding agents can read files, run commands, and spend API credits. Use sandbox repos, least-privilege credentials, and review every diff before committing.',
    url: 'https://github.com/aaif-goose/goose',
  },
  {
    name: 'Internet-in-a-Box',
    category: 'Offline learning server',
    difficulty: 'Intermediate',
    use: 'Raspberry Pi friendly offline knowledge server for Wikipedia, Khan Academy content, OpenStreetMap, books, local apps, and community learning materials.',
    firstStep: 'Read the hardware/install guide and build a small test library before syncing huge content packs.',
    exampleUse: 'Create an offline classroom or workshop hotspot where phones and laptops can browse curated learning material without internet access.',
    command: '# Start with the official install guide:\n# https://wiki.iiab.io/go/FAQ#How_do_I_install_Internet-in-a-Box%3F',
    safetyNote: 'Offline libraries can still expose local uploads, names, documents, and network metadata. Curate content carefully and keep admin access private.',
    url: 'https://github.com/iiab/iiab',
  },
  {
    name: 'Theengs Decoder',
    category: 'IoT payload decoding',
    difficulty: 'Intermediate',
    use: 'Lightweight library for decoding Bluetooth IoT sensor advertisements into readable JSON across ESP32, Arduino, Python, and server workflows.',
    firstStep: 'Browse the supported-device list, then test decoding on your own BLE sensors before integrating it into Home Assistant or MQTT flows.',
    exampleUse: 'Decode temperature, humidity, plant, or presence sensor broadcasts from devices you own so automations can use structured values.',
    command: 'git clone --depth 1 https://github.com/theengs/decoder.git ~/labs/theengs-decoder\ncd ~/labs/theengs-decoder\npipx install platformio\npio --version',
    safetyNote: 'BLE observations can reveal nearby devices, rooms, and habits. Decode only devices you own or are authorized to monitor and avoid publishing identifiers.',
    url: 'https://github.com/theengs/decoder',
  },
  {
    name: 'Domoticz',
    category: 'Home automation',
    difficulty: 'Beginner',
    use: 'Open-source home automation system for Raspberry Pi, Linux, Windows, and macOS with support for Z-Wave, Zigbee, MQTT, Hue, sensors, and scripting.',
    firstStep: 'Run it on a lab Raspberry Pi or VM, add one harmless sensor or switch, and learn the dashboard before connecting critical devices.',
    exampleUse: 'Build a small local dashboard for energy readings, temperature sensors, MQTT devices, or smart-home experiments without starting with a giant stack.',
    command: 'docker run -d --name domoticz --restart unless-stopped -p 8080:8080 -v domoticz_config:/opt/domoticz/userdata domoticz/domoticz:latest',
    safetyNote: 'Home automation can control locks, relays, heaters, and mains-powered devices. Start with read-only sensors and keep the UI off the public internet.',
    url: 'https://github.com/domoticz/domoticz',
  },
  {
    name: 'Pyrrha',
    category: 'Firmware cartography',
    difficulty: 'Advanced',
    use: 'Firmware filesystem cartography tool for mapping relationships between executable files, imports, symbols, symlinks, and other firmware artifacts.',
    firstStep: 'Read the quick-start docs and run it on a known lab firmware image before trying vendor images or proprietary dumps.',
    exampleUse: 'Visualize which binaries in an extracted firmware filesystem depend on BusyBox, shared libraries, or suspicious executable relationships.',
    command: '# Install path depends on optional IDA/Quokka/NumbatUI pieces. Start here:\n# https://quarkslab.github.io/pyrrha/#installation',
    safetyNote: 'Firmware often contains proprietary code, credentials, certificates, or device identifiers. Analyze only firmware you may inspect and do not publish extracted secrets.',
    url: 'https://github.com/quarkslab/pyrrha',
  },
  {
    name: 'Podman Desktop',
    category: 'Container desktop',
    difficulty: 'Beginner',
    use: 'Graphical desktop app for building, running, and managing containers, pods, local Kubernetes, and Podman/Docker-compatible workflows.',
    firstStep: 'Install the desktop app, run one local container, then inspect images, logs, volumes, and Kubernetes features from the UI.',
    exampleUse: 'Help a beginner see what containers, images, ports, and volumes exist before switching to CLI-heavy Podman or Docker workflows.',
    command: '# Download the package for your OS:\n# https://podman-desktop.io/downloads',
    safetyNote: 'Container UIs can start privileged containers, expose ports, and mount local files. Avoid running unknown images or mounting sensitive directories.',
    url: 'https://github.com/podman-desktop/podman-desktop',
  },
  {
    name: 'lazydocker',
    category: 'Docker TUI',
    difficulty: 'Beginner',
    use: 'Terminal UI for Docker and Docker Compose that makes containers, logs, images, volumes, and compose services easier to inspect.',
    firstStep: 'Install it and open it against a disposable Docker Compose project before managing important services.',
    exampleUse: 'Watch logs, restart a broken compose service, inspect ports, and clean up test containers without memorizing every Docker command.',
    command: 'go install github.com/jesseduffield/lazydocker@latest\nlazydocker --version',
    safetyNote: 'Docker management tools can stop services, delete containers, and expose secrets in logs or env views. Use lab stacks first and read before acting.',
    url: 'https://github.com/jesseduffield/lazydocker',
  },
];

const slugify = (value: string) => value
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)/g, '');

const groupMeta = [
  {
    name: 'Hermes + AI agents',
    blurb: 'Start here if you want tools that pair directly with Hermes, local AI, MCP, browser automation, or automation glue.',
    categories: ['AI agent core', 'Automation', 'Local AI', 'Local AI UI', 'AI browser automation', 'AI agent integrations', 'AI agent context control', 'Data-agent context', 'AI agent security', 'AI agent framework', 'AI observability', 'LLM observability', 'AI workflow automation', 'AI agent run inspection', 'AI agent governance', 'AI coding agent'],
  },
  {
    name: 'Build + publish websites',
    blurb: 'The stack behind this site: static pages, deployment, search, and web operations.',
    categories: ['Deploy / web ops', 'Website framework', 'Site search', 'Static blog generator', 'Static gallery generator', 'Deno static-site generator', 'Single-binary static site', 'Documentation site generator'],
  },
  {
    name: 'CLI + systems engineering',
    blurb: 'Everyday tools for Python, terminals, automation, homelabs, monitoring, and keeping machines understandable.',
    categories: ['Python tooling', 'Python CLI apps', 'Command help', 'Sysadmin reference', 'Homelab', 'Monitoring', 'Automation / sysadmin', 'Observability lab', 'Observability collector', 'Homelab monitoring', 'Service monitoring', 'Logs / metrics / traces', 'Dev environment management', 'Command runner', 'Shell productivity', 'System monitoring', 'Container logs', 'Homelab dashboard', 'Kubernetes operations', 'Kubernetes UI', 'Build automation', 'Observability platform', 'Internet monitoring', 'Homelab mapping', 'Infrastructure monitoring', 'Homelab start page', 'Network visualization', 'Observability tutorial', 'Container desktop', 'Docker TUI'],
  },
  {
    name: 'Cybersecurity learning',
    blurb: 'Legal labs, defensive references, and careful scanning tools for owned or explicitly authorized systems.',
    categories: ['Cyber learning', 'Defensive security', 'Web/API debugging', 'Network discovery', 'Vulnerability scanning', 'Recon', 'HTTP probing', 'Web fuzzing', 'Security wordlists', 'Security reference'],
  },
  {
    name: 'Firmware + reverse engineering',
    blurb: 'Firmware extraction, emulation, and reverse-engineering tools. Start small; random BIOS blobs are not beginner projects.',
    categories: ['IoT security lab', 'Firmware analysis', 'Firmware emulation', 'Reverse engineering', 'Reverse engineering GUI', 'Kernel image recovery', 'Firmware analysis platform', 'Firmware cartography'],
  },
  {
    name: 'IoT + hardware labs',
    blurb: 'ESP32, Raspberry Pi, microcontrollers, smart-home firmware, lighting, LoRa, and maker learning.',
    categories: ['ESP32 development', 'Microcontrollers', 'Maker learning', 'ESP32 projects', 'ESP32 / smart-home firmware', 'ESP32 lighting', 'LoRa / mesh radio', 'Microcontroller C/C++', 'Local IoT firmware', 'Embedded development', 'Microcontroller Go', 'Arduino tooling', 'Hardware signal analysis', 'ESP32 live reload', 'Board emulator', 'ESP browser flashing', 'Offline learning server', 'IoT payload decoding', 'Home automation'],
  },
];

const resourceGroups = groupMeta.map((group) => ({
  ...group,
  id: `group-${slugify(group.name)}`,
  slug: slugify(group.name),
  resources: resources.filter((resource) => group.categories.includes(resource.category)),
})).filter((group) => group.resources.length > 0);

const commandCount = resources.filter((resource) => resource.command).length;
const safetyCount = resources.filter((resource) => resource.safetyNote).length;
const resourceStats = [
  [resources.length.toString(), 'curated resources'],
  [resourceGroups.length.toString(), 'resource groups'],
  [commandCount.toString(), 'copy/paste starts'],
  [safetyCount.toString(), 'safety notes'],
];

const resourcesStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Hermie Resources',
    url: 'https://askhermie.dev/resources/',
    description: 'A practical catalog of Hermes Agent resources, AI agent tools, automation utilities, cybersecurity labs, IoT projects, firmware tools, and copy/paste install commands.',
    isPartOf: { '@type': 'WebSite', name: 'askhermie.dev', url: 'https://askhermie.dev/' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Hermie resource map',
    numberOfItems: resources.length,
    itemListElement: resources.map((resource, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: resource.name,
      url: resource.url,
      description: resource.use,
    })),
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title="Hermie Resources — AI agent tools and install commands"
      description="A practical catalog of Hermes Agent resources, AI agent tools, automation utilities, cybersecurity labs, IoT projects, firmware tools, and copy/paste install commands."
      path="/resources/"
      keywords={resourceKeywords}
      structuredData={resourcesStructuredData}
    />
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Hermie home">
        <img src="/assets/hermie-avatar.png" alt="Byte Badger mascot avatar for Hermie" />
        <span>Hermie</span>
      </a>
      <nav aria-label="Primary navigation">
        {nav.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
    </header>

    <main>
      <section class="hero resources-hero">
        <div class="hero-copy">
          <p class="eyebrow">Curated tools // simple installs // practical learning</p>
          <h1>Tools worth installing, not collecting.</h1>
          <p class="lede">A plain-English catalog of tools that work well with Hermes, plus technical resources worth learning. Each card gives you the point, the first move, and a copy/paste command when install makes sense.</p>
        </div>
        <aside class="identity-card compact resource-console" aria-label="Resource rules">
          <p class="card-label">Catalog rules</p>
          <ol>
            <li>Useful with Hermes or real systems work.</li>
            <li>Plain-English value, not vendor fluff.</li>
            <li>Concrete first move or install command.</li>
            <li>Safety context when tools can cause damage.</li>
          </ol>
          <div class="mini-stat-grid">
            {resourceStats.map(([value, label]) => (
              <div>
                <strong>{value}</strong>
                <span>{label}</span>
              </div>
            ))}
          </div>
        </aside>
      </section>

      <section class="resource-control-panel" aria-label="Resource search and filters">
        <div class="resource-search">
          <label for="resource-search-input">Search the catalog</label>
          <input id="resource-search-input" type="search" placeholder="Try: firmware, ESP32, monitoring, MCP, Docker..." autocomplete="off" />
          <p><span id="resource-count">{resources.length}</span> visible resources. Filter by group or search by name, category, use case, command, or safety note.</p>
        </div>
        <div class="filter-chips" role="list" aria-label="Resource groups">
          <button class="filter-chip active" type="button" data-filter="all">All</button>
          {resourceGroups.map((group) => (
            <button class="filter-chip" type="button" data-filter={group.slug}>{group.name}</button>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="section-head">
          <p class="eyebrow">Resource map</p>
          <h2>Everything interesting enough to earn a spot.</h2>
          <p>Commands target Linux/WSL unless the card says otherwise. Security tools are for labs, your own systems, or explicitly authorized work. “Open resource” buttons leave this site.</p>
          <p class="external-link-note">External link note: every <strong>Open resource</strong> button opens the original project/docs site in a new tab.</p>
        </div>
        <div class="category-resource-list">
          {resourceGroups.map((group) => (
            <section class="category-section" id={group.id} data-group={group.slug} aria-labelledby={`${group.id}-heading`}>
              <div class="category-heading">
                <div>
                  <p class="eyebrow">{group.resources.length} {group.resources.length === 1 ? 'resource' : 'resources'}</p>
                  <h3 id={`${group.id}-heading`}>{group.name}</h3>
                </div>
                <p>{group.blurb}</p>
              </div>
              <div class="resource-grid">
                {group.resources.map((resource) => (
                  <article class="resource-card" id={`resource-${slugify(resource.name)}`} data-group={group.slug} data-search={`${resource.name} ${resource.category} ${resource.difficulty} ${resource.use} ${resource.firstStep} ${resource.exampleUse} ${resource.command ?? ''} ${resource.safetyNote ?? ''}`.toLowerCase()}>
                    <div class="resource-topline">
                      <span class="pill">{resource.category}</span>
                      <span class={`difficulty ${resource.difficulty.toLowerCase()}`}>{resource.difficulty}</span>
                    </div>
                    <h2>{resource.name}</h2>
                    <p>{resource.use}</p>
                    <div class="first-step">
                      <strong>First move:</strong>
                      <span>{resource.firstStep}</span>
                    </div>
                    <div class="example-use">
                      <strong>Example use case:</strong>
                      <span>{resource.exampleUse}</span>
                    </div>
                    {resource.safetyNote && (
                      <div class="first-step safety-note">
                        <strong>Safety note:</strong>
                        <span>{resource.safetyNote}</span>
                      </div>
                    )}
                    {resource.command && (
                      <div class="command-box">
                        <div class="command-head">
                          <span>Copy/paste</span>
                          <button class="copy-command" data-copy={resource.command}>Copy</button>
                        </div>
                        <pre><code>{resource.command}</code></pre>
                      </div>
                    )}
                    <a class="resource-link" href={resource.url} target="_blank" rel="noreferrer" aria-label={`${resource.name} external link`}>
                      <span>Open resource</span>
                      <em>External link</em>
                    </a>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <p>Built with Hermie ⚙️</p>
      <p>askhermie.dev/resources</p>
    </footer>

    <script>
      const cards = Array.from(document.querySelectorAll('.resource-card'));
      const sections = Array.from(document.querySelectorAll('.category-section'));
      const chips = Array.from(document.querySelectorAll('.filter-chip'));
      const search = document.querySelector('#resource-search-input');
      const count = document.querySelector('#resource-count');
      let activeFilter = 'all';

      function applyResourceFilters() {
        const query = (search?.value || '').trim().toLowerCase();
        let visibleCount = 0;

        cards.forEach((card) => {
          const groupMatch = activeFilter === 'all' || card.dataset.group === activeFilter;
          const searchMatch = !query || (card.dataset.search || '').includes(query);
          const visible = groupMatch && searchMatch;
          card.hidden = !visible;
          if (visible) visibleCount += 1;
        });

        sections.forEach((section) => {
          const visibleCards = section.querySelectorAll('.resource-card:not([hidden])').length;
          section.hidden = visibleCards === 0;
        });

        if (count) count.textContent = String(visibleCount);
      }

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          activeFilter = chip.dataset.filter || 'all';
          chips.forEach((item) => item.classList.toggle('active', item === chip));
          applyResourceFilters();
        });
      });

      search?.addEventListener('input', applyResourceFilters);
      applyResourceFilters();

      document.querySelectorAll('.copy-command').forEach((button) => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-copy') || '';
          try {
            await navigator.clipboard.writeText(text);
            const old = button.textContent;
            button.textContent = 'Copied';
            setTimeout(() => { button.textContent = old; }, 1300);
          } catch {
            button.textContent = 'Select text';
          }
        });
      });
    </script>
  </body>
</html>
