---
import '../styles/site.css';
import SeoHead from '../components/SeoHead.astro';

const nav = [
  ['Home', '/'],
  ['Resources', '/resources'],
  ['About', '/about'],
  ['Hermes Docs', 'https://hermes-agent.nousresearch.com/docs/'],
];


const resourceKeywords = [
  'AI agent tools',
  'Hermes Agent resources',
  'MCP server list',
  'automation tools',
  'local AI tools',
  'cybersecurity lab tools',
  'IoT tools',
  'ESP32 tools',
  'firmware analysis tools',
  'homelab monitoring tools',
  'copy paste install commands',
  'beginner friendly developer tools',
];

type Resource = {
  name: string;
  category: string;
  use: string;
  firstStep: string;
  exampleUse: string;
  command?: string;
  safetyNote?: string;
  url: string;
  difficulty: 'Beginner' | 'Intermediate' | 'Advanced' | 'Reference';
};

const resources: Resource[] = [
  {
    name: 'Hermes Agent',
    category: 'AI agent core',
    difficulty: 'Beginner',
    use: 'The actual agent framework behind Hermie: CLI, desktop, messaging gateway, skills, memory, cron jobs, MCP, tools.',
    firstStep: 'Install Hermes, run the setup wizard, then add one useful integration instead of trying to configure everything at once.',
    exampleUse: 'Ask Hermie to inspect a repo, run tests, summarize failures, patch the code, and push a verified fix instead of only describing one.',
    command: 'curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash\nhermes setup',
    url: 'https://hermes-agent.nousresearch.com/docs/',
  },
  {
    name: 'Cloudflare Wrangler',
    category: 'Deploy / web ops',
    difficulty: 'Beginner',
    use: 'CLI for Cloudflare Pages and Workers. Useful when Hermie needs to deploy, inspect, or debug Cloudflare projects.',
    firstStep: 'Install Wrangler and log in only when you actually need direct Cloudflare CLI control.',
    exampleUse: 'Use it when a Pages deploy fails and you need to check authentication, project state, or deploy a small Worker from the terminal.',
    command: 'npm install -g wrangler\nwrangler login\nwrangler whoami',
    url: 'https://github.com/cloudflare/workers-sdk',
  },
  {
    name: 'Astro',
    category: 'Website framework',
    difficulty: 'Beginner',
    use: 'Fast static/content-driven sites. This is what askhermie.dev is built with.',
    firstStep: 'Use Astro for docs, catalogs, project pages, and clean static sites before reaching for heavier app frameworks.',
    exampleUse: 'Build a fast docs/catalog site like askhermie.dev where most content is static but still polished and easy to maintain.',
    command: 'npm create astro@latest my-site\ncd my-site\nnpm run dev',
    url: 'https://github.com/withastro/astro',
  },
  {
    name: 'Pagefind',
    category: 'Site search',
    difficulty: 'Beginner',
    use: 'Static search for sites like this. Perfect for a searchable Hermes skill catalog without needing a backend.',
    firstStep: 'Add it after the resources/skills pages have enough content to search.',
    exampleUse: 'Add search once the resource map grows so visitors can type “firmware” or “ESP32” instead of scrolling the whole page.',
    command: 'npm install -D pagefind\nnpx pagefind --site dist',
    url: 'https://github.com/Pagefind/pagefind',
  },
  {
    name: 'n8n',
    category: 'Automation',
    difficulty: 'Beginner',
    use: 'Visual workflow automation with AI integrations. Good for glue jobs: alerts, webhooks, email, GitHub, forms, and agent triggers.',
