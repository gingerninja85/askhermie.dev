    url: 'https://github.com/esp-rs/esp-generate',
  },
  {
    name: 'Inkycal',
    category: 'E-ink desk dashboard',
    difficulty: 'Beginner',
    use: 'Raspberry Pi e-paper dashboard software for calendars, weather, tasks, photos, and custom modules.',
    firstStep: 'Read the manual install docs and configure a small test display with sample/local data before adding calendars or home services.',
    exampleUse: 'Build a low-power desk display that shows a calendar, weather, and one lab status note on an e-paper screen.',
    command: '# Start with the manual install guide:\n# https://aceinnolab.github.io/Inkycal/installation/',
    safetyNote: 'Dashboard modules may use calendars, photos, tasks, locations, and API tokens. Keep config private and verify display wiring before powering hardware.',
    url: 'https://github.com/aceinnolab/Inkycal',
  },
  {
    name: 'Pankha',
    category: 'Infrastructure monitoring',
    difficulty: 'Intermediate',
    use: 'Self-hosted fan and temperature management dashboard for desktops, servers, homelab hosts, and IPMI/BMC-controlled machines.',
    firstStep: 'Run it on one non-critical machine, tune a conservative fan curve, and observe temperatures before managing a fleet.',
    exampleUse: 'Reduce homelab server noise while keeping CPU and drive temperatures visible during builds, backups, or summer heat.',
    command: 'mkdir -p ~/labs/pankha && cd ~/labs/pankha\nwget -O compose.yml https://github.com/Anexgohan/pankha/releases/latest/download/compose.yml\nwget -O .env https://github.com/Anexgohan/pankha/releases/latest/download/example.env\n# Edit .env first; then run:\ndocker compose pull && docker compose up -d',
    safetyNote: 'Fan control can overheat hardware if misconfigured. Use safe fallback curves, monitor temperatures, and do not expose the dashboard or BMC credentials publicly.',
    url: 'https://github.com/Anexgohan/pankha',
  },
  {
    name: 'Nokia DCT3 Emulator',
    category: 'Retro hardware emulator',
    difficulty: 'Advanced',
    use: 'Open-source emulator and architectural-analysis toolkit for obsolete Nokia DCT3 phones that boots bring-your-own firmware in browser or native GUI modes.',
    firstStep: 'Build the emulator and use only a legitimately obtained firmware image from hardware you own or may study.',
    exampleUse: 'Study how a classic Nokia 3310-era phone boots and interacts with its LCD, keypad matrix, DSP, and EEPROM without relying on physical hardware.',
    command: 'git clone --depth 1 https://github.com/djr-747/nokia-dct3-emulator.git ~/labs/nokia-dct3-emulator\ncd ~/labs/nokia-dct3-emulator\nmake all',
    safetyNote: 'The repo intentionally ships no firmware. Do not download or share copyrighted phone firmware, EEPROM dumps, identifiers, or proprietary blobs you are not allowed to use.',
    url: 'https://github.com/djr-747/nokia-dct3-emulator',
  },
];

const slugify = (value: string) => value
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)/g, '');

const groupMeta = [
  {
    name: 'Hermes + AI agents',
    blurb: 'Start here if you want tools that pair directly with Hermes, local AI, MCP, browser automation, or automation glue.',
    categories: ['AI agent core', 'Automation', 'Local AI', 'Local AI UI', 'Local AI / MCP', 'AI browser automation', 'AI agent integrations', 'AI agent context control', 'Data-agent context', 'AI agent security', 'AI agent framework', 'AI observability', 'LLM observability', 'AI workflow automation', 'AI agent run inspection', 'AI agent governance', 'AI coding agent', 'AI agent cost tracking', 'AI agent merge gate', 'AI agent memory', 'AI workflow language', 'AI agent token analytics', 'AI agent provenance', 'Local AI orchestration', 'Durable TypeScript workflows', 'AI document tooling', 'AI supply-chain scanning', 'AI evals and observability', 'Offline developer docs', 'LLM observability tutorial', 'AI codebase maps', 'API agent integration', 'AI media tooling', 'AI code intelligence', 'AI agent loop design', 'Office MCP automation', 'AI agent orchestrator', 'AI gateway', 'MCP gateway', 'MCP registry', 'MCP platform', 'MCP testing', 'MCP bridge', 'AI agent capability manager', 'AI data catalog', 'Mobile app automation', 'Financial data MCP', 'Web data crawler'],
  },
  {
    name: 'Build + publish websites',
    blurb: 'The stack behind this site: static pages, deployment, search, and web operations.',
    categories: ['Deploy / web ops', 'Website framework', 'Site search', 'Static blog generator', 'Static gallery generator', 'Deno static-site generator', 'Single-binary static site', 'Documentation site generator', 'Rsbuild docs generator', 'Privacy web analytics', 'Static site generator', 'Static site CMS', 'Elixir static-site generator', 'Small static-site generator', 'Markdown docs generator', 'SvelteKit SEO tooling', 'PHP static-site generator', 'Living documentation generator', 'WordPress static export', 'Digital garden static site', 'Markdown publishing', 'Agent-native CMS', 'API docs generator'],
