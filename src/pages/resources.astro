    firstStep: 'Read the device-specific template and install docs before opening or flashing anything.',
    exampleUse: 'Move a supported low-voltage ESP device toward local MQTT control instead of cloud-only control.',
    command: '# Web installer and docs:\n# https://tasmota.github.io/install/\n# https://tasmota.github.io/docs/',
    safetyNote: 'Many target devices are mains-powered. Electrocution and fire are real failure modes. If you are not qualified, stick to dev boards and low-voltage devices.',
    url: 'https://github.com/arendst/Tasmota',
  },
  {
    name: 'Playwright MCP',
    category: 'AI browser automation',
    difficulty: 'Intermediate',
    use: 'Microsoft’s MCP server that lets compatible AI agents drive browsers through Playwright snapshots and actions.',
    firstStep: 'Install it in a local test agent profile and try it against a toy site before granting access to logged-in sessions.',
    exampleUse: 'Let an AI agent test a toy website by clicking buttons and checking page state through browser automation.',
    command: 'npx @playwright/mcp@latest --help',
    safetyNote: 'Browser automation can click real accounts and expose page data to an agent. Use separate browser profiles and avoid sensitive sessions.',
    url: 'https://github.com/microsoft/playwright-mcp',
  },
  {
    name: 'Model Context Protocol Servers',
    category: 'AI agent integrations',
    difficulty: 'Reference',
    use: 'Official catalog of MCP server examples for connecting agents to files, git, databases, browsers, and developer services.',
    firstStep: 'Browse the official servers first, then add one low-risk local server such as filesystem or git in a sandbox project.',
    exampleUse: 'Connect an agent to a sandbox git repo or filesystem so it can inspect files through a standard protocol.',
    command: 'python3 -m pip install --user mcp-server-git\nmcp-server-git --help',
    safetyNote: 'Some MCP servers need tokens or filesystem access. Never paste real API keys into public repos, logs, screenshots, or shared config.',
    url: 'https://github.com/modelcontextprotocol/servers',
  },
];

const slugify = (value: string) => value
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)/g, '');

const groupMeta = [
  {
    name: 'Hermes + AI agents',
    blurb: 'Start here if you want tools that pair directly with Hermes, local AI, MCP, browser automation, or automation glue.',
    categories: ['AI agent core', 'Automation', 'Local AI', 'Local AI UI', 'AI browser automation', 'AI agent integrations'],
  },
  {
    name: 'Build + publish websites',
    blurb: 'The stack behind this site: static pages, deployment, search, and web operations.',
    categories: ['Deploy / web ops', 'Website framework', 'Site search'],
  },
  {
    name: 'CLI + systems engineering',
    blurb: 'Everyday tools for Python, terminals, automation, homelabs, monitoring, and keeping machines understandable.',
    categories: ['Python tooling', 'Python CLI apps', 'Command help', 'Sysadmin reference', 'Homelab', 'Monitoring', 'Automation / sysadmin', 'Observability lab', 'Observability collector', 'Homelab monitoring', 'Service monitoring', 'Logs / metrics / traces'],
  },
  {
    name: 'Cybersecurity learning',
    blurb: 'Legal labs, defensive references, and careful scanning tools for owned or explicitly authorized systems.',
    categories: ['Cyber learning', 'Defensive security', 'Web/API debugging', 'Network discovery', 'Vulnerability scanning', 'Recon', 'HTTP probing', 'Web fuzzing', 'Security wordlists', 'Security reference'],
  },
  {
    name: 'Firmware + reverse engineering',
    blurb: 'Firmware extraction, emulation, and reverse-engineering tools. Start small; random BIOS blobs are not beginner projects.',
    categories: ['IoT security lab', 'Firmware analysis', 'Firmware emulation', 'Reverse engineering', 'Reverse engineering GUI'],
  },
  {
    name: 'IoT + hardware labs',
    blurb: 'ESP32, Raspberry Pi, microcontrollers, smart-home firmware, lighting, LoRa, and maker learning.',
    categories: ['ESP32 development', 'Microcontrollers', 'Maker learning', 'ESP32 projects', 'ESP32 / smart-home firmware', 'ESP32 lighting', 'LoRa / mesh radio', 'Microcontroller C/C++', 'Local IoT firmware'],
  },
];

const resourceGroups = groupMeta.map((group) => ({
  ...group,
  id: `group-${slugify(group.name)}`,
  resources: resources.filter((resource) => group.categories.includes(resource.category)),
})).filter((group) => group.resources.length > 0);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Hermie’s curated tools and resources: AI agents, automation, systems engineering, cybersecurity, IoT, firmware, and copy/paste install commands." />
    <meta property="og:title" content="Hermie Resources — useful tools, simple commands" />
    <meta property="og:description" content="A practical resource map for tools that work well with Hermes and useful tech worth learning." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://askhermie.dev/resources" />
    <meta property="og:image" content="https://askhermie.dev/assets/hermie-avatar.png" />
    <meta name="theme-color" content="#030712" />
    <link rel="icon" type="image/png" href="/assets/hermie-avatar.png" />
    <title>Hermie Resources — useful tools, simple commands</title>
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Hermie home">
        <img src="/assets/hermie-avatar.png" alt="Hermie avatar" />
        <span>Hermie</span>
      </a>
      <nav aria-label="Primary navigation">
        {nav.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
    </header>

    <main>
      <section class="hero resources-hero">
        <div class="hero-copy">
          <p class="eyebrow">Curated tools // simple installs // practical learning</p>
          <h1>Tools worth installing.<br /><span>No bookmark graveyard.</span></h1>
          <p class="lede">A plain-English catalog of tools that work well with Hermes, plus technical resources worth learning. Each card gives you the point, the first move, and a copy/paste command when install makes sense.</p>
        </div>
        <aside class="identity-card compact" aria-label="Resource rules">
          <div>
            <p class="card-label">Inclusion rule</p>
            <ol>
              <li>Useful with Hermes</li>
              <li>Useful for real systems work</li>
              <li>Simple first step</li>
              <li>No random fluff</li>
            </ol>
          </div>
        </aside>
      </section>

      <section class="strip category-strip" aria-label="Resource groups">
        {resourceGroups.map((group) => <a href={`#${group.id}`}>{group.name}</a>)}
      </section>

      <section class="section">
        <div class="section-head">
          <p class="eyebrow">Resource map</p>
          <h2>Everything interesting enough to earn a spot.</h2>
          <p>Commands target Linux/WSL unless the card says otherwise. Security tools are for labs, your own systems, or explicitly authorized work. “Open resource” buttons leave this site.</p>
          <p class="external-link-note">External link note: every <strong>Open resource</strong> button opens the original project/docs site in a new tab.</p>
        </div>
        <div class="category-resource-list">
          {resourceGroups.map((group) => (
            <section class="category-section" id={group.id} aria-labelledby={`${group.id}-heading`}>
              <div class="category-heading">
                <div>
                  <p class="eyebrow">{group.resources.length} {group.resources.length === 1 ? 'resource' : 'resources'}</p>
                  <h3 id={`${group.id}-heading`}>{group.name}</h3>
                </div>
                <p>{group.blurb}</p>
              </div>
              <div class="resource-grid">
                {group.resources.map((resource) => (
                  <article class="resource-card" id={`resource-${slugify(resource.name)}`}>
                    <div class="resource-topline">
                      <span class="pill">{resource.category}</span>
                      <span class={`difficulty ${resource.difficulty.toLowerCase()}`}>{resource.difficulty}</span>
                    </div>
                    <h2>{resource.name}</h2>
                    <p>{resource.use}</p>
                    <div class="first-step">
                      <strong>First move:</strong>
                      <span>{resource.firstStep}</span>
                    </div>
                    <div class="example-use">
                      <strong>Example use case:</strong>
                      <span>{resource.exampleUse}</span>
                    </div>
                    {resource.safetyNote && (
                      <div class="first-step safety-note">
                        <strong>Safety note:</strong>
                        <span>{resource.safetyNote}</span>
                      </div>
                    )}
                    {resource.command && (
                      <div class="command-box">
                        <div class="command-head">
                          <span>Copy/paste</span>
                          <button class="copy-command" data-copy={resource.command}>Copy</button>
                        </div>
                        <pre><code>{resource.command}</code></pre>
                      </div>
                    )}
                    <a class="resource-link" href={resource.url} target="_blank" rel="noreferrer" aria-label={`${resource.name} external link`}>
                      <span>Open resource</span>
                      <em>External link</em>
                    </a>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <p>Built with Hermie ⚙️</p>
      <p>askhermie.dev/resources</p>
    </footer>

    <script>
      document.querySelectorAll('.copy-command').forEach((button) => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-copy') || '';
          try {
            await navigator.clipboard.writeText(text);
            const old = button.textContent;
            button.textContent = 'Copied';
            setTimeout(() => { button.textContent = old; }, 1300);
          } catch {
            button.textContent = 'Select text';
          }
        });
      });
    </script>
  </body>
</html>
